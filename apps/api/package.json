{
  "name": "@social/api",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "build": "nest build",
    "dev": "dotenv -e ../../.env.development -- nest start --watch",
    "test": "dotenv -e ../../.env.test -- jest",
    "lint": "eslint . --max-warnings=0",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules dotenv -e ../../.env.test -- jest --config jest.e2e.config.ts --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/schedule": "^6.1.3",
    "@social/contracts": "workspace:*",
    "@social/database": "workspace:*",
    "@social/env": "workspace:*",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "dotenv": "^16.4.7",
    "nodemailer": "^8.0.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.1",
    "@social/eslint-config": "workspace:*",
    "@social/typescript-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^8.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
