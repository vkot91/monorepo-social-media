{
  "name": "@social/database",
  "private": true,
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:db:migrate": "dotenv -e ../../.env.test -- pnpm build && dotenv -e ../../.env.test -- node dist/scripts/migrate-test-database.js",
    "test:db:reset": "dotenv -e ../../.env.test -- pnpm build && dotenv -e ../../.env.test -- node dist/scripts/reset-test-database.js",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@social/env": "workspace:*",
    "pg": "^8.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@social/eslint-config": "workspace:*",
    "@social/typescript-config": "workspace:*",
    "@types/node": "^22.5.4",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.7",
    "prisma": "^7.8.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.31.0",
    "dotenv-cli": "^11.0.0"
  }
}
