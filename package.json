{
  "name": "social-media-new",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build",
    "check:affected": "turbo run lint typecheck test:coverage build --affected",
    "ci": "pnpm check",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "prepare": "husky",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@social/prettier-config": "workspace:*",
    "husky": "^9.1.7",
    "prettier": "^3.3.3",
    "turbo": "^2.9.6",
    "typescript": "^5.5.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
